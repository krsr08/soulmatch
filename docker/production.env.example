NODE_ENV=production
CORS_ORIGINS=https://soulmatch.app,https://admin.soulmatch.app

# Core infrastructure
POSTGRES_USER=soulmatch_user
POSTGRES_PASSWORD=replace_with_strong_database_password
POSTGRES_DB=soulmatch_db
DB_HOST=postgres
DB_PORT=5432
DB_NAME=soulmatch_db
DB_USER=soulmatch_user
DB_PASSWORD=replace_with_strong_database_password
REDIS_HOST=redis
REDIS_PORT=6379
MONGO_URI=mongodb://mongodb:27017/soulmatch_chat

# Auth, admin, and internal service auth
JWT_SECRET=replace_with_64_byte_random_secret
REFRESH_TOKEN_SECRET=replace_with_different_64_byte_random_secret
JWT_EXPIRES_IN=15m
JWT_ISSUER=soulmatch-auth
JWT_AUDIENCE=soulmatch-api
JWT_REFRESH_AUDIENCE=soulmatch-refresh
REFRESH_TOKEN_EXPIRES_IN=7d
ADMIN_JWT_SECRET=replace_with_different_64_byte_random_secret
ADMIN_EMAIL=admin@soulmatch.app
ADMIN_PASSWORD_HASH=replace_with_bcrypt_hash
ADMIN_ROLE=super_admin
INTERNAL_SERVICE_SECRET=replace_with_internal_service_secret

# Third-party integrations
TWILIO_ACCOUNT_SID=replace_with_twilio_sid
TWILIO_AUTH_TOKEN=replace_with_twilio_token
TWILIO_PHONE_NUMBER=+10000000000
GOOGLE_CLIENT_ID=replace_with_google_client_id
GOOGLE_CLIENT_SECRET=replace_with_google_client_secret
RAZORPAY_KEY_ID=replace_with_razorpay_key_id
RAZORPAY_KEY_SECRET=replace_with_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=replace_with_razorpay_webhook_secret
DOCUMENT_ENCRYPTION_KEY=replace_with_base64_or_hex_32_byte_document_key
DOCUMENT_HASH_PEPPER=replace_with_random_hash_pepper
FIREBASE_PRIVATE_KEY="replace_with_firebase_private_key"
FIREBASE_PROJECT_ID=replace_with_firebase_project_id
FIREBASE_CLIENT_EMAIL=replace_with_firebase_client_email
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=replace_with_aws_access_key
AWS_SECRET_ACCESS_KEY=replace_with_aws_secret_key
AWS_S3_BUCKET=replace_with_s3_bucket
USE_LOCAL_STORAGE=false
LOCAL_UPLOAD_DIR=/app/uploads

# Owner control plane and service URLs
ADMIN_API_PUBLIC_URL=https://admin-api.soulmatch.app/api/v1/admin
AUTH_SERVICE_URL=http://auth-service:3001/health
PROFILE_SERVICE_URL=http://profile-service:3002/health
MATCHING_SERVICE_URL=http://matching-service:3003/health
SEARCH_SERVICE_URL=http://search-service:3004/health
CHAT_SERVICE_URL=http://chat-service:3005/health
NOTIFICATION_SERVICE_URL=http://notification-service:3006/health
PAYMENT_SERVICE_URL=http://payment-service:3007/health
NOTIFICATION_API_URL=http://notification-service:3006/api/v1/notifications

# Cost-safe architecture extension placeholders.
# Keep these defaults during development. Changing them does not provision cloud
# resources by itself; it only tells code/config which future adapter mode is intended.
EDGE_WAF_MODE=nginx-basic
MOBILE_BFF_ENABLED=false
MOBILE_BFF_URL=
BLOB_STORAGE_PROVIDER=local
MEDIA_SIGNED_URLS_ENABLED=false
ASYNC_QUEUE_PROVIDER=none
SEARCH_ENGINE_PROVIDER=postgres
OPENSEARCH_URL=
OBSERVABILITY_PROVIDER=none
PROMETHEUS_ENABLED=false
GRAFANA_ENABLED=false
MAX_MONTHLY_CLOUD_COST_INR=1000
REQUIRE_APPROVAL_FOR_PAID_RESOURCES=true

# Local-only development toggles - keep disabled in production
MOCK_OTP=false
OTP_PHONE_LIMIT=3
OTP_IP_LIMIT=10

# Optional off-VM production backup upload
AZURE_BACKUP_CONTAINER=soulmatch-backups
AZURE_STORAGE_CONNECTION_STRING=replace_with_azure_storage_connection_string

# Optional production monitor alert webhook
ALERT_WEBHOOK_URL=
ADMIN_ALERT_API_URL=http://127.0.0.1:3011/api/v1/admin/system/alerts

# Optional AI-assisted profile copy, ice-breakers, and moderation.
# Do not commit real keys; configure these as production secrets.
AI_ASSIST_ENABLED=false
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=replace_with_anthropic_key
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
AI_TIMEOUT_MS=8000
CHAT_MODERATION_BLOCK_HIGH_RISK=true
CHAT_MODERATION_AI_ENABLED=false
