{
  "title": "SoulMatch Production Overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Request rate by service",
      "targets": [
        {
          "expr": "sum by (service) (rate(soulmatch_http_requests_total[5m]))"
        }
      ],
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 }
    },
    {
      "type": "timeseries",
      "title": "5xx error rate",
      "targets": [
        {
          "expr": "sum(rate(soulmatch_http_requests_total{status_class=\"5xx\"}[5m])) / clamp_min(sum(rate(soulmatch_http_requests_total[5m])), 1)"
        }
      ],
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 }
    },
    {
      "type": "timeseries",
      "title": "p95 latency by service",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, service) (rate(soulmatch_http_request_duration_seconds_bucket[5m])))"
        }
      ],
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 }
    },
    {
      "type": "timeseries",
      "title": "OTP failures",
      "targets": [
        {
          "expr": "sum(rate(soulmatch_http_requests_total{service=\"auth-service\",route=~\".*otp.*\",status_class=~\"4xx|5xx\"}[5m]))"
        }
      ],
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 }
    },
    {
      "type": "stat",
      "title": "Notification DLQ depth",
      "targets": [
        {
          "expr": "soulmatch_notification_dlq_depth"
        }
      ],
      "gridPos": { "x": 0, "y": 16, "w": 6, "h": 4 }
    },
    {
      "type": "stat",
      "title": "Admin live users",
      "targets": [
        {
          "expr": "soulmatch_admin_live_users"
        }
      ],
      "gridPos": { "x": 6, "y": 16, "w": 6, "h": 4 }
    }
  ]
}
