NODE_ENV=development
PORT=3002
DB_HOST=localhost
DB_PORT=5432
DB_NAME=soulmatch_db
DB_USER=soulmatch_user
DB_PASSWORD=soulmatch_pass
REDIS_HOST=localhost
REDIS_PORT=6379
JWT_SECRET=change_this_to_very_long_secret_key_min_32_chars
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=soulmatch-media-dev
USE_LOCAL_STORAGE=true
LOCAL_UPLOAD_DIR=./uploads

# Optional AI assists. Keep disabled until a production key and consent copy are configured.
AI_ASSIST_ENABLED=false
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=replace_with_anthropic_key
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
AI_TIMEOUT_MS=8000
