NODE_ENV=development
PORT=3005
MONGO_URI=mongodb://localhost:27017/soulmatch_chat
DB_HOST=localhost
DB_PORT=5432
DB_NAME=soulmatch_db
DB_USER=soulmatch_user
DB_PASSWORD=soulmatch_pass
REDIS_HOST=localhost
REDIS_PORT=6379
JWT_SECRET=change_this_to_very_long_secret_key_min_32_chars

# Chat safety moderation. Rule checks run locally; AI is optional.
CHAT_MODERATION_BLOCK_HIGH_RISK=true
CHAT_MODERATION_AI_ENABLED=false
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=replace_with_anthropic_key
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
AI_TIMEOUT_MS=7000
